{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(npm install:*)",
      "Bash(npm test:*)",
      "Bash(node:*)",
      "Bash(npm run lint)",
      "Bash(npm run build:*)",
      "Bash(mkdir:*)",
      "Bash(npx tsc:*)",
      "Bash(npx jest:*)",
      "Bash(rg:*)",
      "Bash(npm run lint:*)",
      "Bash(npx eslint:*)",
      "Bash(npm run test:*)",
      "Bash(sed:*)",
      "Read(//Users/elrocie/**)",
      "Read(//Users/elrocie/.claude/**)",
      "Bash(git clone:*)",
      "Bash(git config:*)",
      "Bash(GIT_TRACE=1 timeout 120 git clone https://github.com/zbirenbaum/copilot.lua.git)",
      "Bash(ping:*)",
      "Bash(git restore:*)",
      "Bash(git reset:*)",
      "Bash(test:*)",
      "Bash(git checkout:*)",
      "Bash(git add:*)",
      "WebFetch(domain:github.com)",
      "Bash(git rebase:*)",
      "WebSearch",
      "Bash(git rm:*)"
    ],
    "deny": [],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/elrocie/.claude/hooks/gsd-check-update.js\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/elrocie/.claude/hooks/gsd-session-state.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/elrocie/.claude/hooks/gsd-context-monitor.js\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/elrocie/.claude/hooks/gsd-phase-boundary.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/elrocie/.claude/hooks/gsd-prompt-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/elrocie/.claude/hooks/gsd-read-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/elrocie/.claude/hooks/gsd-workflow-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/elrocie/.claude/hooks/gsd-validate-commit.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node \"/Users/elrocie/.claude/hooks/gsd-statusline.js\""
  },
  "enabledPlugins": {
    "commit-commands@claude-code-plugins": true,
    "pr-review-toolkit@claude-code-plugins": true,
    "feature-dev@claude-code-plugins": true,
    "code-review@claude-code-plugins": true,
    "frontend-design@claude-code-plugins": true,
    "typescript-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "gitlab@claude-plugins-official": true,
    "huggingface-skills@claude-plugins-official": true
  },
  "model": "claude-opus-4-6",
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "planStoragePath": ".planning",
  "feedbackSurveyState": {
    "lastShownTime": 1754041961165
  },
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--user-data-dir",
        "/Users/elrocie/.playwright-profiles",
        "--channel",
        "chrome"
      ]
    }
  }
}
