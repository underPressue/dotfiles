# show desktop
# cmd + alt + ctrl + shift - f : osascript -e 'tell application "System Events" to keystroke "f" using {command down, control down}'
cmd + alt + ctrl + shift - h : osascript -e 'tell application "System Events" to keystroke "h" using {command down}'

# Map Control + Return to switch input source
ctrl - return : osascript -e 'tell application "System Events" to key code 49 using {control down, shift down}'




