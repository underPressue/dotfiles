cmd + alt + ctrl + shift - h : skhd -k "cmd - h"

# Map Control + Return to switch input source
ctrl - return : osascript -e 'tell application "System Events" to key code 49 using {control down, shift down}'

cmd + alt + ctrl + shift - tab : skhd -k "cmd - tab"
cmd + alt + ctrl + shift - delete : open -a "cmd - q"

# Attach iPad (Uranus) as Sidecar display
cmd + alt + ctrl + shift - e : ~/Sidecar connect Uranus

